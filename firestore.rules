rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function chatPath(chatId) {
      return /databases/$(database)/documents/interest_chats/$(chatId);
    }

    function isChatParticipant(chatId) {
      return signedIn()
        && request.auth.uid in get(chatPath(chatId)).data.participantIds;
    }

    function isFriendChatCreate() {
      return signedIn()
        && request.resource.data.type == 'friend_dm'
        && request.resource.data.participantIds is list
        && request.auth.uid in request.resource.data.participantIds;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;

      match /workouts/{workoutId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /food_entries/{entryId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /saved_food_products/{productId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /weight_history/{entryId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /daily_metrics/{entryId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /friends/{friendId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow write: if signedIn()
          && (request.auth.uid == userId || request.auth.uid == friendId);
      }

      match /social_settings/{settingId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    match /friend_invites/{inviteId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerUserId == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.ownerUserId == request.auth.uid;
    }

    match /friend_requests/{requestId} {
      allow read: if signedIn()
        && (resource.data.fromUserId == request.auth.uid
          || resource.data.toUserId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.status == 'pending';
      allow update: if signedIn()
        && (resource.data.fromUserId == request.auth.uid
          || resource.data.toUserId == request.auth.uid);
      allow delete: if signedIn()
        && (resource.data.fromUserId == request.auth.uid
          || resource.data.toUserId == request.auth.uid);
    }

    match /interest_chats/{chatId} {
      allow read: if isChatParticipant(chatId);
      allow create: if isFriendChatCreate()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0;
      allow update: if isChatParticipant(chatId)
        || (isFriendChatCreate()
          && request.resource.data.createdBy == request.auth.uid);
      allow delete: if isChatParticipant(chatId)
        && resource.data.createdBy == request.auth.uid;

      match /members/{userId} {
        allow read, write: if signedIn();
      }

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.message is string
          && request.resource.data.message.size() > 0;
        allow delete: if isChatParticipant(chatId);
      }

      match /moderation_logs/{logId} {
        allow read, write: if isChatParticipant(chatId);
      }
    }
  }
}
